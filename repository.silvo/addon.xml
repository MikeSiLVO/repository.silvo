<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="repository.silvo" name="SiLVO Development Repository" version="1.0.0" provider-name="SiLVO">
    <requires>
        <import addon="xbmc.addon" version="12.0.0"/>
    </requires>
    <extension point="xbmc.addon.repository" name="SiLVO Dev Repo">
        <!-- Pre-Release Channel: Beta versions with normal addon IDs -->
        <!-- These will upgrade to stable versions from official Kodi repo -->
        <dir minversion="21.0.0">
            <info compressed="false">https://raw.githubusercontent.com/MikeSiLVO/repository.silvo/main/pre-release/addons.xml</info>
            <checksum>https://raw.githubusercontent.com/MikeSiLVO/repository.silvo/main/pre-release/addons.xml.md5</checksum>
            <datadir zip="true">https://raw.githubusercontent.com/MikeSiLVO/repository.silvo/main/pre-release/</datadir>
            <hashes>true</hashes>
        </dir>

        <!-- Testing Channel: Experimental versions with modified IDs (.test suffix) -->
        <!-- These install side-by-side with production versions -->
        <dir minversion="21.0.0">
            <info compressed="false">https://raw.githubusercontent.com/MikeSiLVO/repository.silvo/main/testing/addons.xml</info>
            <checksum>https://raw.githubusercontent.com/MikeSiLVO/repository.silvo/main/testing/addons.xml.md5</checksum>
            <datadir zip="true">https://raw.githubusercontent.com/MikeSiLVO/repository.silvo/main/testing/</datadir>
            <hashes>true</hashes>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">SiLVO Development Repository</summary>
        <description lang="en_GB">Development and pre-release repository for Aeon Nox: SiLVO skin and related addons. Contains beta versions for testing before official Kodi repo releases, plus experimental testing versions with modified IDs for side-by-side installation.</description>
        <disclaimer lang="en_GB">Pre-release software may contain bugs. Use at your own risk. Stable versions are available in the official Kodi repository.</disclaimer>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
